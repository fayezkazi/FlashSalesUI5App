<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <SelectDialog
        id="companyCodeVHDialog"
        title="Company Code"
        multiSelect="true"
        search=".onCompanyCodeVHSearch"
        confirm=".onCompanyCodeVHConfirm"
        cancel=".onVHCancel"
        growing="true"
        growingThreshold="50"
        noDataText="No company codes found"
        items="{
            path: 'I_CompanyCode>/I_CompanyCode'
        }">
        <StandardListItem id ="companyCodeVHItem"
            title="{I_CompanyCode>CompanyCode}"
            description="{I_CompanyCode>CompanyCodeName}"
            info="{I_CompanyCode>Country}"
        />
    </SelectDialog>

</core:FragmentDefinition>