<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="companyCodeVHDialog"
        title="Company Code"
        contentWidth="50%"
        draggable="true"
        resizable="true"
        class="flashSalesVHDialog">

        <subHeader>
            <Bar class="flashSalesVHSubHeader">
                <contentMiddle>
                    <SearchField
                        id="companyCodeVHSearchField"
                        liveChange=".onCompanyCodeVHSearch"
                        width="100%" />
                </contentMiddle>
                <contentRight>
                    <Button text="Select All"   press=".onCompanyCodeVHSelectAll" />
                    <Button text="Deselect All" press=".onCompanyCodeVHDeselectAll" />
                </contentRight>
            </Bar>
        </subHeader>

        <content>
            <List
                id="companyCodeVHList"
                class="flashSalesVHList"
                mode="MultiSelect"
                growing="true"
                growingThreshold="50"
                noDataText="No company codes found"
                items="{
                    path: 'I_CompanyCode>/I_CompanyCode'
                }">
                <StandardListItem
                    id="companyCodeVHItem"
                    title="{I_CompanyCode>CompanyCode}"
                    description="{I_CompanyCode>CompanyCodeName}"
                    info="{I_CompanyCode>Country}" />
            </List>
        </content>

        <beginButton>
            <Button text="OK" type="Emphasized" press=".onCompanyCodeVHConfirm" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onVHCancel" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>