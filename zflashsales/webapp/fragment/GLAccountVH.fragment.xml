<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="glAccountVHDialog"
        title="G/L Account"
        contentWidth="50%"
        draggable="true"
        resizable="true"
        class="flashSalesVHDialog">

        <subHeader>
            <Bar class="flashSalesVHSubHeader">
                <contentMiddle>
                    <SearchField
                        id="glAccountVHSearchField"
                        liveChange=".onGLAccountVHSearch"
                        width="100%" />
                </contentMiddle>
                <contentRight>
                    <Button text="Select All"   press=".onGLAccountVHSelectAll" />
                    <Button text="Deselect All" press=".onGLAccountVHDeselectAll" />
                </contentRight>
            </Bar>
        </subHeader>

        <content>
            <List
                id="glAccountVHList"
                class="flashSalesVHList"
                mode="MultiSelect"
                growing="true"
                growingThreshold="50"
                noDataText="No G/L accounts found"
                items="{
                    path: 'I_GLAccountStdVH>/I_GLAccountStdVH'
                }">
                <StandardListItem
                    id="glAccountVHItem"
                    title="{I_GLAccountStdVH>GLAccount}"
                    description="{I_GLAccountStdVH>GLAccount_Text}"
                    info="{I_GLAccountStdVH>CompanyCode}"
                    type="Active" />
            </List>
        </content>

        <beginButton>
            <Button text="OK" type="Emphasized" press=".onGLAccountVHConfirm" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onVHCancel" />
        </endButton>

    </Dialog>
</core:FragmentDefinition>
