<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <SelectDialog
        id="glAccountVHDialog"
        title="G/L Account"
        multiSelect="true"
        search=".onGLAccountVHSearch"
        confirm=".onGLAccountVHConfirm"
        cancel=".onVHCancel"
        growing="true"
        growingThreshold="50"
        noDataText="No G/L accounts found"
        items="{
            path: 'I_GLAccountStdVH>/I_GLAccountStdVH'
        }">

        <StandardListItem id="glAccountVHItem"
            title="{I_GLAccountStdVH>GLAccount}"
            description="{I_GLAccountStdVH>GLAccount_Text}"
            info="{I_GLAccountStdVH>CompanyCode}"
            type="Active" />

    </SelectDialog>
</core:FragmentDefinition>
